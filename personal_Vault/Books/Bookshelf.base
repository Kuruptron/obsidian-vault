formulas:
  Untitled: ""
  Progress: (pages_read/pages_total*100).toFixed(2) + " %"
views:
  - type: cards
    name: All Books
    filters:
      and:
        - file.inFolder("Books")
        - file.hasProperty("Title")
    groupBy:
      property: status
      direction: DESC
    order:
      - Title
      - status
      - author
      - rating
      - genre
      - formula.Progress
    image: note.cover
    imageFit: contain
